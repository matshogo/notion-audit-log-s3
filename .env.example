# X (Twitter) API
# X Developer Portal で取得: https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=your_x_bearer_token_here

# Notion API
# Notion Integration で取得: https://www.notion.so/my-integrations
NOTION_API_TOKEN=your_notion_api_token_here

# Notion データベース ID
# DB の URL から取得: https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=your_database_id_here
